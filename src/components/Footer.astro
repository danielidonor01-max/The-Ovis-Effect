---
import { getSiteSettings } from '../lib/getSiteSettings';

const settings = await getSiteSettings();
const { name, address, email, whatsapp } = settings;
const waHref = `https://wa.me/${whatsapp}`;
---
<footer class="global-footer" id="footer" data-reveal>
  <div class="container footer-inner">

    <div class="footer-main">

      <!-- Col 1: Brand & Contact -->
      <div class="footer-brand">
        <h3>{name}</h3>
        <p>{address}</p>
        <div class="footer-contact">
          <a href={waHref} target="_blank" rel="noopener noreferrer" class="contact-link">
            <div class="contact-icon">
              <svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
            </div>
            Chat on WhatsApp
          </a>
          <a href={`mailto:${email}`} class="contact-link">
            <div class="contact-icon">
              <svg viewBox="0 0 24 24"><path d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6zm-2 0l-8 5-8-5h16zm0 12H4V8l8 5 8-5v10z"/></svg>
            </div>
            {email}
          </a>
        </div>
      </div>

      <!-- Col 2: Newsletter -->
      <div class="footer-newsletter">
        <h4>Subscribe to Our Newsletter</h4>
        <p>Be the first to know about our latest updates, recipes and financial offerings</p>
        <form class="newsletter-form" onsubmit="return false;">
          <input type="email" placeholder="Email" id="newsletter-email" autocomplete="email">
          <button type="submit" aria-label="Subscribe">
            <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14m-7-7 7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </form>
      </div>

      <!-- Col 3: Directory -->
      <div class="footer-links">
        <h4>Directory</h4>
        <ul>
          <li><a href="/good-food-avenue/">Good Food Avenue</a></li>
          <li><a href="/urovi-spa/">Urovi Spa</a></li>
          <li><a href="/financial-advisory/">Financial Advisory</a></li>
          <li><a href="/safe-haven/">Safe Haven Apartments</a></li>
        </ul>
      </div>
    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom">
      <p>&copy; 2026 {name}. All rights reserved.</p>
      <a href="/" class="footer-logo">OVIS<span>.</span></a>
      <p>Warri, Delta State</p>
    </div>

  </div>
</footer>
