---
/**
 * Context-aware intro / page-transition overlay (on every page via BaseLayout).
 *
 * Modes (decided client-side from sessionStorage + isHome):
 *  - welcome : first load of the session on home -> geometry, cycle hubs,
 *              "The Ovis Effect" full-width, sound/silent choice.
 *  - home    : subsequent home load -> geometry + hub listing -> reveal.
 *  - inner   : any hub/Contact page -> geometry lists hubs (destination last)
 *              -> destination name full-width -> reveal. Faster, no sound UI.
 */
interface Props {
  isHome?: boolean;
  displayName?: string;   // full-width name (home: "The Ovis Effect")
  nameStyle?: string;     // inline style for the name (brand font/colour)
  brandOrder?: string[];  // hub names in cycle order (destination last)
  audioUrl?: string;
}
const {
  isHome = false,
  displayName = 'The Ovis Effect',
  nameStyle = '',
  brandOrder = ['Good Food Avenue', 'Urovi Spa', 'Financial Advisory', 'Safe Haven'],
  audioUrl = '/audio/ovis-ambient.mp3',
} = Astro.props;
---
<div id="ovis-preloader" class="ovis-preloader" data-home={isHome ? 'true' : 'false'} role="dialog" aria-modal="true" aria-label="Loading The Ovis Effect">

  <!-- Ambient background particles -->
  <div class="pre-particles" aria-hidden="true">
    <span></span><span></span><span></span><span></span>
    <span></span><span></span><span></span><span></span>
  </div>

  <div class="preloader-inner">

   <div class="pre-headline">
    <!-- Geometry stage: ring + orbiting accent + cycling hub names -->
    <div class="pre-stage" aria-hidden="true">
      <svg class="pre-geo" viewBox="0 0 200 200" fill="none">
        <circle class="pre-geo-ring" cx="100" cy="100" r="82"/>
        <circle class="pre-geo-ring pre-geo-ring--inner" cx="100" cy="100" r="62"/>
        <g class="pre-geo-orbit">
          <circle class="pre-geo-orbit-dot" cx="100" cy="18" r="3.5"/>
        </g>
        <circle class="pre-geo-core" cx="100" cy="100" r="3"/>
      </svg>
      <div class="pre-brands">
        {brandOrder.map((name) => (
          <span class="pre-brand">{name}</span>
        ))}
      </div>
    </div>

    <!-- Full-width name (The Ovis Effect on home-welcome, page name on inner) -->
    <div class="pre-fullname" aria-hidden="true">
      <span class="pre-fullname-text" style={nameStyle || undefined}>{displayName}</span>
    </div>
   </div>

    <!-- Prompt + sound choice (welcome only) -->
    <div class="pre-prompt-wrap">
      <p class="pre-prompt">How would you like to experience this?</p>
      <div class="preloader-choices">
        <button type="button" class="preloader-btn preloader-btn--sound" data-enter="sound">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M11 5 6 9H2v6h4l5 4V5z"/>
            <path d="M15.5 8.5a5 5 0 0 1 0 7"/>
            <path d="M19 5a9 9 0 0 1 0 14"/>
          </svg>
          Enter with Sound
        </button>
        <button type="button" class="preloader-btn preloader-btn--silent" data-enter="silent">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M11 5 6 9H2v6h4l5 4V5z"/>
            <line x1="23" y1="9" x2="17" y2="15"/>
            <line x1="17" y1="9" x2="23" y2="15"/>
          </svg>
          Enter Silently
        </button>
      </div>
    </div>
  </div>

  <audio id="preloader-audio" src={audioUrl} loop preload="auto"></audio>
</div>

<!-- Persistent floating audio toggle -->
<button id="ovis-audio-toggle" class="audio-toggle" aria-label="Toggle ambient audio" aria-pressed="false" hidden>
  <svg class="audio-icon audio-icon--on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M15.5 8.5a5 5 0 0 1 0 7"/><path d="M19 5a9 9 0 0 1 0 14"/>
  </svg>
  <svg class="audio-icon audio-icon--off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M11 5 6 9H2v6h4l5 4V5z"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>
  </svg>
</button>

<script>
  (() => {
    const root   = document.getElementById('ovis-preloader') as HTMLElement | null;
    const toggle = document.getElementById('ovis-audio-toggle') as HTMLButtonElement | null;
    const audio  = document.getElementById('preloader-audio') as HTMLAudioElement | null;
    if (!root) return;

    const isHome   = root.dataset.home === 'true';
    const brands   = Array.from(root.querySelectorAll<HTMLElement>('.pre-brand'));

    const firstThisSession = !sessionStorage.getItem('ovis_session');
    sessionStorage.setItem('ovis_session', '1');
    const soundPref = sessionStorage.getItem('ovis_sound'); // 'on' | 'off' | null

    // Mode
    const mode = (firstThisSession && isHome) ? 'welcome' : (isHome ? 'home' : 'inner');
    const fast = mode !== 'welcome';
    const k    = fast ? 0.55 : 1;            // speed factor
    const at   = (ms: number) => Math.round(ms * k);

    document.body.classList.add('preloader-active');

    let dismissed = false;

    // --- audio helpers ---
    let fadeInterval: number | null = null;
    const fadeAudioIn = () => {
      if (!audio) return;
      if (!audio.paused && audio.volume >= 0.5) return; // already playing & at target
      
      if (fadeInterval) clearInterval(fadeInterval);
      
      if (audio.paused) {
        audio.volume = 0;
        audio.play().catch(() => {});
      }
      
      fadeInterval = window.setInterval(() => {
        audio.volume = Math.min(audio.volume + 0.04, 0.5);
        if (audio.volume >= 0.5) {
          clearInterval(fadeInterval!);
          fadeInterval = null;
        }
      }, 80);
    };

    const fadeAudioOut = () => {
      if (!audio) return;
      if (fadeInterval) clearInterval(fadeInterval);
      
      fadeInterval = window.setInterval(() => {
        audio.volume = Math.max(audio.volume - 0.05, 0);
        if (audio.volume <= 0) {
          clearInterval(fadeInterval!);
          fadeInterval = null;
          audio.pause();
        }
      }, 60);
    };

    const showToggle = (soundOn: boolean) => {
      if (!toggle) return;
      toggle.hidden = false;
      toggle.setAttribute('aria-pressed', String(soundOn));
      toggle.classList.toggle('is-muted', !soundOn);
      requestAnimationFrame(() => toggle.classList.add('is-visible'));
    };

    // --- dismiss: iris reveal into the page ---
    const enter = (withSound: boolean) => {
      if (dismissed) return;
      dismissed = true;
      sessionStorage.setItem('ovis_sound', withSound ? 'on' : 'off');
      if (withSound) fadeAudioIn();
      root.classList.add('is-leaving');
      document.body.classList.remove('preloader-active');
      window.setTimeout(() => root.remove(), at(1100));
      window.setTimeout(() => showToggle(withSound), at(1000));
    };

    // --- brand-name cycle ---
    const start = at(650);
    const per   = at(mode === 'welcome' ? 520 : 380);
    brands.forEach((el, i) => {
      window.setTimeout(() => el.classList.add('active'), start + i * per);
      if (i < brands.length - 1) {
        window.setTimeout(() => el.classList.remove('active'), start + i * per + per);
      }
    });
    const cycleEnd = start + brands.length * per;

    if (mode === 'welcome') {
      window.setTimeout(() => root.classList.add('show-name'), cycleEnd);
      window.setTimeout(() => root.classList.add('show-buttons'), cycleEnd + at(550));
      root.querySelectorAll<HTMLButtonElement>('[data-enter]').forEach((btn) => {
        btn.addEventListener('click', () => enter(btn.dataset.enter === 'sound'));
      });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') enter(false); }, { once: true });
    } else if (mode === 'inner') {
      window.setTimeout(() => root.classList.add('show-name'), cycleEnd);
      window.setTimeout(() => enter(soundPref === 'on'), cycleEnd + at(1000));
    } else { // home (subsequent)
      window.setTimeout(() => enter(soundPref === 'on'), cycleEnd + at(300));
    }

    // Subsequent pages: browsers block autoplay on a fresh load, so resume the
    // ambient track on the first user interaction if sound is the saved choice.
    if (mode !== 'welcome' && soundPref === 'on') {
      const resume = () => { if (audio && audio.paused) fadeAudioIn(); };
      document.addEventListener('pointerdown', resume, { once: true });
      document.addEventListener('keydown', resume, { once: true });
    }

    // --- persistent audio toggle ---
    if (toggle) {
      toggle.addEventListener('click', () => {
        const on = toggle.classList.contains('is-muted'); // currently muted -> turn on
        toggle.classList.toggle('is-muted', !on);
        toggle.setAttribute('aria-pressed', String(on));
        sessionStorage.setItem('ovis_sound', on ? 'on' : 'off');
        if (on) fadeAudioIn(); else fadeAudioOut();
      });
    }
  })();
</script>
