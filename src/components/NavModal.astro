---
import { siteConfig, otherBrands } from '../lib/siteConfig';
import { getSiteSettings } from '../lib/getSiteSettings';

interface LocalLink { href: string; label: string; }
interface Props {
  variant: 'hub' | 'brand';
  /** Required for variant === 'brand': current page slug (excluded from cross-links) */
  activeSlug?: string;
  /** Required for variant === 'brand': in-page section anchors */
  localLinks?: LocalLink[];
}
const { variant, activeSlug = '', localLinks = [] } = Astro.props;
const crossBrands = otherBrands(activeSlug);
const settings = await getSiteSettings();
const closeSvg = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>`;
---
<div id="nav-modal" class="nav-modal" aria-hidden="true">
  <div class="nav-modal-backdrop"></div>
  <div class="nav-modal-inner">

    <div class="modal-header">
      {variant === 'hub' ? (
        <a href="/" class="logo" style="color: var(--color-hub-text);">OVIS<span style="color: var(--color-hub-gold);">.</span></a>
      ) : (
        <a href="/" class="modal-home-btn">HOME</a>
      )}
      <button class="modal-close" id="modal-close" aria-label="Close Menu">
        Menu <Fragment set:html={closeSvg} />
      </button>
    </div>

    <div class="modal-body">
      {variant === 'hub' ? (
        <div class="modal-hub-links">
          {siteConfig.brands.map((b) => (
            <a href={`/${b.slug}/`}>{b.shortName}</a>
          ))}
        </div>
      ) : (
        <>
          <div class="modal-global-links">
            {crossBrands.map((b) => (
              <a href={`/${b.slug}/`}>{b.name}</a>
            ))}
          </div>
          <div class="modal-local-links">
            {localLinks.map((l) => (
              <a href={l.href}>{l.label}</a>
            ))}
          </div>
        </>
      )}
    </div>

    {variant === 'hub' && (
      <div class="modal-cta-group">
        <a href="/contact" class="modal-home-btn" style="background-color: var(--color-hub-gold); color: #000;">Contact us</a>
      </div>
    )}

    <hr class="modal-divider">

    <div class="modal-footer">
      <div class="footer-left">
        <p class="modal-tagline">{settings.tagline}</p>
        <div class="modal-contact">
          <a href={`mailto:${settings.email}`}>{settings.email}</a>
          <a href={`tel:${settings.phoneTel}`}>{settings.phoneDisplay}</a>
        </div>
        <div class="modal-social">
          <a href={settings.social.facebook} aria-label="Facebook"><svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>
          <a href={settings.social.instagram} aria-label="Instagram"><svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>
          <a href={settings.social.tiktok} aria-label="TikTok"><svg viewBox="0 0 24 24"><path d="M9 0h1.98c.144 2.58 1.964 4.5 4.02 4.5v3c-1.294 0-2.527-.406-3.52-1.127v8.627c0 3.86-3.14 7-7 7s-7-3.14-7-7 3.14-7 7-7c1.379 0 2.663.4 3.738 1.085v3.42C10.428 11.895 9.743 11.5 9 11.5c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V0z"/></svg></a>
        </div>
      </div>
      <div class="footer-right">
        <p>{settings.address}</p>
      </div>
    </div>
  </div>
</div>
