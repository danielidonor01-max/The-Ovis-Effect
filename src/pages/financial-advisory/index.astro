---
import { sanityClient } from "sanity:client";
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import NavModal from '../../components/NavModal.astro';
import { siteConfig } from '../../lib/siteConfig';
import './style.css';

let brandData = null;
try {
  brandData = await sanityClient.fetch(`*[_type == "brand" && slug.current == "financial-advisory"][0]`);
} catch (error) {
  console.warn("Sanity fetch failed:", error.message);
}

const pageTitle = brandData?.seo?.metaTitle || "Financial Advisory | The Ovis Effect";
const metaDesc = brandData?.seo?.metaDescription || "Financial Services for MSMEs tailored to scale your business.";
const heroTitleHTML = brandData?.heroHeadline || "Financial services for <span>MSMEs</span>, tailored to scale your <span>business.</span>";
const introText = brandData?.heroSub || "Bookkeeping, tax compliance, and advisory built for Nigerian MSMEs — structured to scale with you.";

const brand = siteConfig.brands.find((b) => b.slug === 'financial-advisory')!;
const localLinks = [{"href":"#about","label":"Overview"},{"href":"#pricing","label":"MSME Packages"},{"href":"#contact","label":"Contact"}];

// Testimonials — pulled from Sanity (brand.testimonials), else these fallbacks.
const fallbackReviews = [
  { quote: "They brought real structure to our books — for the first time I actually understand my numbers." },
  { quote: "Tax season used to terrify me. Now it's handled, on time, every single time." },
  { quote: "The advisory calls alone paid for the package. Clear, honest, practical guidance." },
  { quote: "Professional, discreet, and genuinely invested in our growth. Exactly what we needed." },
  { quote: "From messy receipts to clean financial statements — the difference has been night and day." },
];
const reviewQuotes = (brandData?.testimonials ?? []).filter((t) => t?.quote);
const reviewList = reviewQuotes.length ? reviewQuotes : fallbackReviews;
---
<BaseLayout title={pageTitle} description={metaDesc} preloaderName="Financial Advisory" preloaderSlug="financial-advisory">

  <Header variant="brand" brand={brand} />
  <NavModal variant="brand" activeSlug="financial-advisory" localLinks={localLinks} />

<main>
    <!-- Finance Hero -->
    <section class="fin-hero-viewport">
      <!-- Floating transaction cards -->
      <div class="fin-hero-floats" aria-hidden="true">
        <div class="float-card fc-1">
          <span class="fc-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2h9l3 3v17l-3-2-3 2-3-2-3 2V2z"/><path d="M9 7h6M9 11h6M9 15h3"/></svg>
          </span>
          <div class="fc-body">
            <span class="fc-label">Tax remitted</span>
            <span class="fc-amount pos">+₦70,000</span>
          </div>
        </div>
        <div class="float-card fc-2">
          <span class="fc-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5a2 2 0 0 1 2-2h13v16H6a2 2 0 0 0-2 2V5z"/><path d="M4 19a2 2 0 0 1 2-2h13"/></svg>
          </span>
          <div class="fc-body">
            <span class="fc-label">Bookkeeping</span>
            <span class="fc-status">Reconciled</span>
          </div>
        </div>
        <div class="float-card fc-3">
          <span class="fc-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="13" rx="2"/><path d="M2 10h20M6 15h4"/></svg>
          </span>
          <div class="fc-body">
            <span class="fc-label">Payroll run</span>
            <span class="fc-amount">₦1,240,000</span>
          </div>
        </div>
      </div>

      <div class="container fin-hero-inner">
        <h1 class="fin-hero-text hero-animate-title" set:html={heroTitleHTML}></h1>
        <p class="fin-hero-sub">{introText}</p>
        <div class="fin-hero-actions">
          <a href="#pricing" class="fin-hero-btn">
            Explore packages
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="fin-stats-bar" data-reveal>
      <div class="container stats-inner">
        <div class="stat-item">
          <h2 class="stat-number" data-count="240" data-suffix="k">0</h2>
          <p>PAYE Generated for the last<br>couple of years</p>
        </div>
        <div class="stat-item">
          <h2 class="stat-number" data-count="100" data-suffix="+">0</h2>
          <p>Tax advisory<br>sessions</p>
        </div>
        <div class="stat-item">
          <h2 class="stat-number" data-count="270" data-suffix="+">0</h2>
          <p>Happy clients all<br>over Nigeria</p>
        </div>
      </div>
    </section>

    <!-- Growth Panel -->
    <section class="fin-growth-section" data-reveal>
      <div class="container">
        <div class="growth-card">
          <div class="growth-card-text">
            <p class="growth-eyebrow">Proven momentum</p>
            <h2>Grow your<br>business faster</h2>
            <p class="growth-desc">Structured books, clean tax compliance, and advisory that compounds — so your numbers keep trending the right way.</p>
            <a href="#pricing" class="growth-cta">
              See the packages
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="growth-chart-wrap">
            <svg class="growth-svg" viewBox="0 0 300 160" preserveAspectRatio="none" aria-hidden="true">
              <defs>
                <linearGradient id="growthGradient" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#8FE3D2" stop-opacity="0.35"/>
                  <stop offset="100%" stop-color="#8FE3D2" stop-opacity="0"/>
                </linearGradient>
              </defs>
              <line class="grid-line" x1="0" y1="40" x2="300" y2="40"/>
              <line class="grid-line" x1="0" y1="80" x2="300" y2="80"/>
              <line class="grid-line" x1="0" y1="120" x2="300" y2="120"/>
              <path class="growth-area" d="M0,148 L50,128 L100,96 L150,104 L200,60 L250,48 L300,18 L300,160 L0,160 Z"/>
              <path class="growth-line" pathLength="1" d="M0,148 L50,128 L100,96 L150,104 L200,60 L250,48 L300,18"/>
            </svg>
            <span class="growth-dot"></span>
          </div>
        </div>
      </div>
    </section>

    <!-- About / Trust -->
    <section class="fin-about-section" id="about" data-reveal>
      <div class="container fin-about-inner">
        <div class="fin-about-portrait">
          <svg class="placeholder-icon-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a6 6 0 0 1 6-6h4a6 6 0 0 1 6 6v1"/></svg>
          <div class="fin-about-caption">
            <span class="about-name">Dhaniel Khaniels</span>
            <span class="about-role">Founder &amp; Lead Advisor</span>
          </div>
        </div>
        <div class="fin-about-text">
          <p class="fin-about-eyebrow">About</p>
          <h2 class="fin-about-title">Finance partners <em>you can trust.</em></h2>
          <p class="fin-about-desc">For years we've helped business owners across Delta State and beyond bring order to their books, stay compliant, and make confident decisions with their money. From your first invoice to full CFO-level support, our advisory is built on precision, discretion, and a genuine stake in your growth.</p>
          <div class="fin-about-points">
            <div class="fin-about-point">
              <span class="point-num">270+</span>
              <span class="point-label">businesses served nationwide</span>
            </div>
            <div class="fin-about-point">
              <span class="point-num">100%</span>
              <span class="point-label">focused on Nigerian MSMEs</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="fin-pricing-section" id="pricing" data-reveal>
      <div class="container">
        <h2 class="pricing-title">OUR PLANS TO TAKE YOUR BUSINESS TO NEW HEIGHTS</h2>
      </div>
      <div class="container pricing-mega-card">
          
          <div class="pricing-cell">
            <div class="pricing-cell-inner">
              <div class="cell-head">
                <h3>FS 4 Nano</h3>
                <p>For businesses that generate less than ₦3,000,000 per year.</p>
              </div>
              <div class="cell-amount">
                <span class="cur">NGN</span><span class="val">10,000</span><span class="dur">/month</span>
              </div>
              <a href="https://wa.me/2348077125775?text=Hi,%20I'm%20interested%20in%20the%20FS%204%20Nano%20package." class="cell-btn">Select Nano</a>
              <ul class="cell-list">
                <li>Business/Individual Qualifications</li>
                <li>Assets and Liabilities Identification</li>
                <li>Income and Expenditure Categorisation</li>
                <li>Preparation of Petty Cash Account</li>
                <li>Income and Expenditure Statement</li>
              </ul>
            </div>
          </div>

          <div class="pricing-cell featured">
            <span class="cell-badge">Most Popular</span>
            <div class="pricing-cell-inner">
              <div class="cell-head">
                <h3>FS 4 Micro</h3>
                <p>For businesses that generate less than ₦25,000,000 per year.</p>
              </div>
              <div class="cell-amount">
                <span class="cur">NGN</span><span class="val">20,000</span><span class="dur">/month</span>
              </div>
              <a href="https://wa.me/2348077125775?text=Hi,%20I'm%20interested%20in%20the%20FS%204%20Micro%20package." class="cell-btn">Select Micro</a>
              <ul class="cell-list">
                <li>All FS 4 Nano Ent. Packages</li>
                <li>Tax Filing Services (PAYE, VAT)</li>
                <li>Payroll Services (Max 5)</li>
                <li>Quarterly tax compliance reminders</li>
                <li>Preparation of Profit/Loss Account</li>
              </ul>
            </div>
          </div>

          <div class="pricing-cell">
            <div class="pricing-cell-inner">
              <div class="cell-head">
                <h3>FS 4 Small</h3>
                <p>For businesses that generate less than ₦100,000,000 per year.</p>
              </div>
              <div class="cell-amount">
                <span class="cur">NGN</span><span class="val">40,000</span><span class="dur">/month</span>
              </div>
              <a href="https://wa.me/2348077125775?text=Hi,%20I'm%20interested%20in%20the%20FS%204%20Small%20package." class="cell-btn">Select Small</a>
              <ul class="cell-list">
                <li>All FS 4 Micro Ent. Packages</li>
                <li>Inventory Management & Costing</li>
                <li>Product/Service Pricing</li>
                <li>Bank Reconciliation (Max 4 banks)</li>
                <li>Preparation of Financial Statements</li>
              </ul>
            </div>
          </div>

          <div class="pricing-cell">
            <div class="pricing-cell-inner">
              <div class="cell-head">
                <h3>AFS 4 Small</h3>
                <p>Advanced Financial Services for small businesses.</p>
              </div>
              <div class="cell-amount">
                <span class="cur">NGN</span><span class="val">60,000</span><span class="dur">/month</span>
              </div>
              <a href="https://wa.me/2348077125775?text=Hi,%20I'm%20interested%20in%20the%20AFS%204%20Small%20package." class="cell-btn">Select Advance Small</a>
              <ul class="cell-list">
                <li>All FS 4 Small Ent. Packages</li>
                <li>Budgeting & financial planning</li>
                <li>Monthly tax advisory support</li>
                <li>Qualitative & Quantitative Analysis</li>
                <li>Monthly review call (Zoom/physical)</li>
              </ul>
            </div>
          </div>

          <div class="pricing-cell">
            <div class="pricing-cell-inner">
              <div class="cell-head">
                <h3>FS 4 Medium</h3>
                <p>Financial Services for businesses making > ₦100,000,000.</p>
              </div>
              <div class="cell-amount">
                <span class="cur">NGN</span><span class="val">100,000</span><span class="dur">/month</span>
              </div>
              <a href="https://wa.me/2348077125775?text=Hi,%20I'm%20interested%20in%20the%20FS%204%20Medium%20package." class="cell-btn">Select Medium</a>
              <ul class="cell-list">
                <li>All AFS 4 Small Ent. Packages</li>
                <li>Tax Filing (PAYE, VAT, CIT, WHT)</li>
                <li>Payroll Services (Max 15)</li>
                <li>Advanced forecasting & scenario planning</li>
                <li>Annual financial statement review</li>
              </ul>
            </div>
          </div>

          <div class="pricing-cell">
            <div class="pricing-cell-inner">
              <div class="cell-head">
                <h3>AFS 4 Medium</h3>
                <p>Advanced Financial Services for medium scalable businesses.</p>
              </div>
              <div class="cell-amount">
                <span class="cur">NGN</span><span class="val">500,000+</span><span class="dur">/month</span>
              </div>
              <a href="https://wa.me/2348077125775?text=Hi,%20I'm%20interested%20in%20the%20AFS%204%20Medium%20package." class="cell-btn">Select CFO Advance</a>
              <ul class="cell-list">
                <li>Full Chief Financial Officer Services</li>
                <li>All FS 4 Medium Ent. Packages</li>
              </ul>
            </div>
          </div>
          
        </div>
      </div>
    </section>

    <!-- Customer Reviews (Carousel) — identical to Urovi Spa -->
    <section class="spa-reviews-section" id="reviews">
      <div class="reviews-viewport">
        <div class="reviews-track" id="reviews-track">
          {reviewList.map((r) => (
            <article class="review-card">
              <div class="review-inner">
                <div class="review-quote-icon">
                  <svg viewBox="0 0 54 54" fill="currentColor">
                    <text x="2" y="46" font-size="60" font-family="Georgia, serif" opacity="0.9">"</text>
                  </svg>
                </div>
                <p class="review-text">{r.quote}</p>
              </div>
            </article>
          ))}
        </div>
      </div>

      <!-- Reviews scroll progress (mobile only) -->
      <div class="reviews-progress-wrap mobile-only-flex">
        <div class="reviews-progress-track">
          <div class="reviews-progress-bar" id="reviews-progress-bar"></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CTA: LET'S TALK
         ══════════════════════════════════════════ -->
    <section class="fin-cta-section" id="contact" data-reveal>
      <div class="container">
        <div class="fin-cta-inner">
          <div class="fin-cta-text">
            <p class="fin-cta-eyebrow">Let's Talk</p>
            <h2 class="fin-cta-title">The right financial advice <em>changes everything.</em></h2>
            <p class="fin-cta-sub">Hundreds of business owners across Delta State trust us with their books, payroll, and tax compliance. Join them today.</p>
          </div>
          <div class="fin-cta-action">
            <a href="https://wa.me/2348077125775?text=Hi,%20I'd%20like%20to%20speak%20with%20a%20financial%20advisor%20at%20The%20Ovis%20Effect..." class="fin-cta-btn">
              Get in Touch
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <p class="fin-cta-note">Via WhatsApp · Mon–Fri, 8am–5pm</p>
          </div>
        </div>
      </div>
    </section>

  </main>


  <!-- Sticky WA CTA -->
  <a href="https://wa.me/2348077125775?text=Hi,%20I'm%20interested%20in%20your%20financial%20advisory%20packages..." class="sticky-wa-btn" aria-label="Book via WhatsApp">
    <svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
  </a>

  <!-- Global Footer -->

  <Fragment slot="scripts">
    <script src="../../scripts/financial-advisory-images.js"></script>
    <script>
      /* ── REVIEWS SCROLL-BASED PROGRESS BAR (identical to Urovi Spa) ── */
      (function () {
        const track    = document.getElementById('reviews-track');
        const progBar  = document.getElementById('reviews-progress-bar');

        if (!track) return;

        const isMobile = window.matchMedia('(max-width: 768px)').matches;

        if (isMobile) {
          /* Mobile: native scroll on track, progress bar updates on scroll */
          track.addEventListener('scroll', () => {
            if (!progBar) return;
            const scrollLeft = track.scrollLeft;
            const maxScroll  = track.scrollWidth - track.clientWidth;
            const ratio      = maxScroll > 0 ? scrollLeft / maxScroll : 0;
            progBar.style.width = (40 + ratio * 60) + '%';
          }, { passive: true });
        } else {
          /* Desktop: wheel-driven page carousel */
          const CARDS    = track.children.length || 6;
          const PER_PAGE = 3;
          const PAGES    = Math.ceil(CARDS / PER_PAGE);
          let   current  = 0;

          function goTo(index) {
            current = Math.max(0, Math.min(index, PAGES - 1));
            const cardWidth = 372;
            track.style.transform = `translateX(-${current * PER_PAGE * cardWidth}px)`;
            if (progBar) progBar.style.width = (current / (PAGES - 1) * 60 + 40) + '%';
          }

          const section = document.getElementById('reviews');
          let cooldown  = false;
          section && section.addEventListener('wheel', (e) => {
            if (cooldown) return;
            e.preventDefault();
            cooldown = true;
            goTo(current + (e.deltaY > 0 ? 1 : -1));
            setTimeout(() => { cooldown = false; }, 800);
          }, { passive: false });

          goTo(0);
        }
      })();
    </script>
  </Fragment>
</BaseLayout>
