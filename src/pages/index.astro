---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import NavModal from '../components/NavModal.astro';
import BrandCard from '../components/BrandCard.astro';
import { getSiteSettings } from '../lib/getSiteSettings';
import { getHubCards } from '../lib/getHubCards';

const settings = await getSiteSettings();
const hubCards = await getHubCards();
const pageTitle = settings.defaultSeo?.metaTitle || "The Ovis Effect | Warri";
const metaDesc = settings.defaultSeo?.metaDescription || "The Ovis Effect: A central brand hub for Good Food Avenue, Urovi Spa, Financial Advisory and Safe Haven Apartments based in Warri, Delta State.";
const heroHeadline = 'Wealth, <span class="gold-text">Appetite</span> &amp; Wellbeing';
const heroSubtext = 'One roof, four houses — food, calm, comfort and capital.';

// Interactive hero panels — one per house, tinted with its brand accent.
const houses = [
  { href: '/good-food-avenue/',   name: 'Good Food Avenue',   tag: 'Appetite',  desc: 'Premium Nigerian dishes, grills & fresh drinks.', accent: '#FF5B04' },
  { href: '/urovi-spa/',          name: 'Urovi Spa',          tag: 'Wellbeing', desc: 'Therapies to restore your body and mind.',       accent: '#8BAF8A' },
  { href: '/financial-advisory/', name: 'Financial Advisory', tag: 'Wealth',    desc: 'Strategies for growth, built on trust.',         accent: '#8FE3D2' },
  { href: '/safe-haven/',         name: 'Safe Haven',         tag: 'Exclusive', desc: 'Discreet luxury apartment stays.',               accent: '#D4B47A' },
];
---
<BaseLayout title={pageTitle} description={metaDesc}>

  <Header variant="hub" />
  <NavModal variant="hub" />

  <main>

    <!-- Hero: interactive Four Houses -->
    <section class="houses-hero">
      <div class="houses-hero-intro">
        <h1 class="houses-hero-title hero-animate-title" set:html={heroHeadline}></h1>
        <p class="houses-hero-sub hero-animate-sub">{heroSubtext}</p>
      </div>

      <div class="houses-panels">
        {houses.map((h, i) => (
          <a href={h.href} class="house-panel" style={`--house-accent:${h.accent}; --i:${i}`} aria-label={`Enter ${h.name}`}>
            <span class="house-panel-tag">{h.tag}</span>
            <span class="house-panel-body">
              <span class="house-panel-name">{h.name}</span>
              <span class="house-panel-desc">{h.desc}</span>
              <span class="house-panel-enter">
                Enter
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="stats-bar" data-reveal>
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item">
            <span class="stat-number" data-count="4" data-pad="2">04</span>
            <p>Branded houses, one standard</p>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number" data-count="460" data-suffix="+">460+</span>
            <p>Clients guided nationwide</p>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number" data-count="10" data-suffix="k+">10k+</span>
            <p>Guests served &amp; counting</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Our Branded House Section -->
    <section class="brands-section" id="brands" data-reveal>
      <div class="container">

        <div class="section-header section-intro--center">
          <p class="section-eyebrow">The Ovis Effect</p>
          <h2 class="section-heading">Our Branded Houses</h2>
          <p class="section-lead">Four businesses for lifestyle, finance, and wellbeing.</p>
        </div>

        <div class="brand-grid">
          {hubCards.map((card, i) => <BrandCard {...card} delay={i + 1} />)}
        </div>
      </div>
    </section>

    <!-- Closing CTA — shared .cta-band (hub uses the default orange accent) -->
    <section class="cta-band" data-reveal>
      <div class="container">
        <div class="cta-band__inner">
          <p class="cta-band__eyebrow">The Ovis Effect</p>
          <h2 class="cta-band__title">One standard across <em>every house.</em></h2>
          <p class="cta-band__sub">Not sure which house you need? Send a message — we're in Warri, Delta State, and always happy to help.</p>
          <a href="/contact/" class="cta-band__btn">
            Get in touch
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

  </main>

</BaseLayout>
