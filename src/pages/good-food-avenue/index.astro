---
import { sanityClient } from "sanity:client";
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import NavModal from '../../components/NavModal.astro';
import { siteConfig } from '../../lib/siteConfig';
import { buildBrandImages } from '../../lib/brandImages';
import './style.css';

let brandData = null;
try {
  brandData = await sanityClient.fetch(`*[_type == "brand" && slug.current == "good-food-avenue"][0]{
    ...,
    "menuPdfUrl": menuPdf.asset->url
  }`);
} catch (error) {
  console.warn("Sanity fetch failed:", error.message);
}

const pageTitle = brandData?.seo?.metaTitle || "Good Food Avenue | The Ovis Effect";
const metaDesc = brandData?.seo?.metaDescription || "Warri's favourite spot for premium Nigerian dishes, grills, and fresh fruit drinks. Order directly to your door.";
const heroTitleHTML = brandData?.heroHeadline || "Taste the <span class=\"text-vibrancy\">Vibrancy.</span>";
const introText = brandData?.heroSub || "Premium Nigerian delicacies, prepared with authentic spices and delivered directly to you across Warri.";

const brand = siteConfig.brands.find((b) => b.slug === 'good-food-avenue')!;
const localLinks = [{"href":"#about","label":"About"},{"href":"#services","label":"Services"},{"href":"#gallery","label":"Gallery"},{"href":"#reviews","label":"Reviews"},{"href":"#contact","label":"Contact"}];

const brandImages = buildBrandImages(brandData, {
  extra: [
    { field: 'gfaCategoryImages', slots: ['main_meal', 'soups_stews', 'proteins', 'snacks_drinks', 'side_dishes'] },
  ],
});

// ── Order-builder menu (price-optional; ready to source from Sanity later) ──
// Each item may carry an optional `price` (number, Naira). When present the
// order bar shows a live total; when absent it sends an itemised order to confirm.
const fallbackMenu = [
  { key: 'mains', label: 'Mains', items: [
    { name: 'Asun Rice',    desc: 'Spicy rice tossed with peppered, smoky goat meat (asun).' },
    { name: 'Chinese Rice', desc: 'Stir-fried rice with mixed vegetables and a savoury twist.' },
    { name: 'Native Rice',  desc: "Palm-oil 'concoction' rice cooked with local spices, fish and greens." },
    { name: 'Jollof Rice',  desc: 'Smoky party-style jollof simmered in a rich pepper-tomato sauce.' },
    { name: 'Fried Rice',   desc: 'Colourful fried rice with vegetables, liver and sweet corn.' },
    { name: 'White Rice',   desc: 'Plain steamed long-grain rice — perfect with any stew.' },
    { name: 'Spaghetti',    desc: 'Nigerian-style peppered spaghetti, jollof or stir-fried.' },
  ]},
  { key: 'soups', label: 'Soups & Stews', items: [
    { name: 'Egusi Soup',         desc: 'Melon-seed soup rich with assorted meat and leafy greens.' },
    { name: 'Okra Soup',          desc: 'Light, draw okra soup with peppers and assorted meat.' },
    { name: 'Vegetable Soup',     desc: 'Hearty edikang-ikong-style greens with fish and meat.' },
    { name: 'Banga Soup',         desc: 'Delta palm-fruit soup with native spices and fresh catfish.' },
    { name: 'Regular Stew',       desc: 'Classic fried pepper-and-tomato stew.' },
    { name: 'Buka Peppered Stew', desc: 'Bold, roadside-style buka stew — extra peppered.' },
    { name: 'Eba',                desc: 'Smooth garri swallow, moulded warm.' },
    { name: 'Semo',               desc: 'Soft semolina swallow, great with any soup.' },
  ]},
  { key: 'proteins', label: 'Proteins', items: [
    { name: 'Sauced Turkey',        desc: 'Turkey simmered in a spicy tomato-pepper sauce.' },
    { name: 'Grilled Turkey',       desc: 'Smoky, char-grilled turkey.' },
    { name: 'Chicken',              desc: 'Tender, well-seasoned chicken.' },
    { name: 'Sauced Chicken',       desc: 'Chicken in a rich peppered sauce.' },
    { name: 'Chicken Wings',        desc: 'Crispy seasoned wings.' },
    { name: 'Sauced Chicken Wings', desc: 'Wings tossed in a spicy sauce.' },
    { name: 'Gizzard',              desc: 'Peppered gizzard — gizdodo-ready.' },
    { name: 'Beef',                 desc: 'Soft, seasoned beef cuts.' },
    { name: 'Fish',                 desc: 'Grilled or fried titus / croaker.' },
    { name: 'Eggs',                 desc: 'Boiled or fried egg.' },
  ]},
  { key: 'snacks', label: 'Snacks & Drinks', items: [
    { name: 'Ice Cream',     desc: 'Chilled, creamy scoop.' },
    { name: 'Yoghurt Drink', desc: 'Cold sweet or plain yoghurt.' },
    { name: 'Fruit Juice',   desc: 'Freshly blended fruit juice.' },
    { name: 'Tigernut',      desc: 'Chilled tigernut milk (kunu aya).' },
    { name: 'Beer',          desc: 'Chilled bottle.' },
    { name: 'Super Roll',    desc: 'Sausage-roll-style savoury snack.' },
    { name: 'Chicken Pie',   desc: 'Flaky pie with a savoury chicken filling.' },
    { name: 'Small Chops',   desc: 'Puff-puff, spring rolls, samosa & gizzard mix.' },
  ]},
  { key: 'sides', label: 'Sides', items: [
    { name: 'Salad',    desc: 'Fresh garden salad / coleslaw.' },
    { name: 'Moi Moi',  desc: 'Steamed bean pudding with pepper and fish or egg.' },
    { name: 'Plantain', desc: 'Fried sweet plantain (dodo).' },
  ]},
];
const slugify = (s) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

// Prefer live menu items from Sanity; fall back to the built-in list above.
const CAT_LABELS = { mains: 'Mains', soups: 'Soups & Stews', proteins: 'Proteins', snacks: 'Snacks & Drinks', sides: 'Sides' };
const CAT_ORDER = ['mains', 'soups', 'proteins', 'snacks', 'sides'];
let menuDocs = [];
try {
  menuDocs = await sanityClient.fetch(`*[_type == "menuItem" && available != false]|order(category asc, sortOrder asc, name asc){
    name, "id": slug.current, category, description, price, "img": image.asset->url
  }`);
} catch (error) {
  console.warn('menuItem fetch failed; using built-in list:', error.message);
}

let orderItems, orderMenu;
if (Array.isArray(menuDocs) && menuDocs.length) {
  orderItems = menuDocs.map((d) => ({
    name: d.name,
    desc: d.description || '',
    cat: d.category,
    catLabel: CAT_LABELS[d.category] || d.category,
    id: d.id || slugify(d.name),
    price: d.price ?? null,
    img: d.img || null,
  }));
  orderMenu = CAT_ORDER.filter((k) => orderItems.some((i) => i.cat === k)).map((k) => ({ key: k, label: CAT_LABELS[k] }));
} else {
  orderItems = fallbackMenu.flatMap((c) =>
    c.items.map((it) => ({ name: it.name, desc: it.desc, cat: c.key, catLabel: c.label, id: slugify(it.name), price: null, img: null }))
  );
  orderMenu = fallbackMenu.map((c) => ({ key: c.key, label: c.label }));
}
const waNumber = '2348077125775';
// Image-ready placeholder avatar (swapped for a real photo when an item has one)
const bowlIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11h18a9 9 0 0 1-18 0Z"/><path d="M7.5 11a4.5 4.5 0 0 1 9 0"/><path d="M12 3.5v1.4"/></svg>`;
---
<BaseLayout title={pageTitle} description={metaDesc} preloaderName="Good Food Avenue" preloaderSlug="good-food-avenue">

  <Fragment slot="head">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
  </Fragment>

  <Header variant="brand" brand={brand} />
  <NavModal variant="brand" activeSlug="good-food-avenue" localLinks={localLinks} />

<main>

    <!-- GFA Hero Viewport -->
    <section class="gfa-hero-viewport">
      <div class="container hero-container">
        <!-- Mobile Logo -->
        <div class="mobile-hero-logo">
          <span class="subbrand-logo gfa-pacifico-logo">Good Food<br>Avenue</span>
        </div>

        <!-- Main Image Placeholder spanning max-width -->
        <div class="hero-image-placeholder" data-img-key="hero">
          <svg class="placeholder-icon-large" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
          </svg>
        </div>
        
        <!-- Category Short Links -->
        <div class="hero-categories">
          <a href="#main-meal" class="category-link">Main Meal</a>
          <span class="cat-divider">•</span>
          <a href="#soups-stews" class="category-link">Soups</a>
          <span class="cat-divider">•</span>
          <a href="#soups-stews" class="category-link">Stew</a>
          <span class="cat-divider">•</span>
          <a href="#proteins" class="category-link">Proteins</a>
          <span class="cat-divider">•</span>
          <a href="#snacks-drinks" class="category-link">Drinks</a>
          <span class="cat-divider">•</span>
          <a href="#snacks-drinks" class="category-link">Snacks</a>
          <span class="cat-divider">•</span>
          <a href="#side-dishes" class="category-link">Side Dishes</a>
        </div>
        
        <!-- Hero Heading -->
        <div class="hero-heading-wrap">
          <h1 class="hero-animate-title" set:html={heroTitleHTML}></h1>
        </div>
      </div>
    </section>

    <!-- Intro Section -->
    <section class="gfa-intro-section-wrapper" data-reveal>
      <div class="gfa-intro-section container">
        <p class="intro-text text-scrub">{introText}</p>
        <div class="intro-actions">
          <a href={brandData?.menuPdfUrl || "#"} class="view-menu-link" target="_blank" rel="noopener noreferrer">View Full Menu PDF <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7 7 7-7 7"/></svg></a>
        </div>
      </div>
    </section>

    <!-- Zig-Zag Category Layout Section -->
    <section class="gfa-menu-zigzag">
      
      <!-- Category 1: Main Meal -->
      <article class="zigzag-row container" id="main-meal" data-reveal>
        <div class="zigzag-image">
          <div class="placeholder-box" data-img-key="main_meal">
             <svg class="placeholder-icon-large" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
             </svg>
          </div>
        </div>
        <div class="zigzag-content">
          <h3>Main Meal</h3>
          <p>We offer Asun Rice, Chinese Rice, Native Rice, Jollof Rice, Fried Rice, White Rice, and Spaghetti.</p>
        </div>
      </article>

      <!-- Category 2: Soups and Stews -->
      <article class="zigzag-row reverse container" id="soups-stews" data-reveal>
        <div class="zigzag-content">
          <h3>Soups and Stews</h3>
          <p>We offer Egusi Soup, Okra Soup, Vegetable Soup, Banga Soup, Regular Stew, Buka Peppered Stew with swallows like Eba and Semo.</p>
        </div>
        <div class="zigzag-image">
          <div class="placeholder-box portrait" data-img-key="soups_stews">
             <svg class="placeholder-icon-large" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
             </svg>
          </div>
        </div>
      </article>

      <!-- Category 3: Proteins -->
      <article class="zigzag-row container" id="proteins" data-reveal>
        <div class="zigzag-image">
          <div class="placeholder-box portrait" data-img-key="proteins">
             <svg class="placeholder-icon-large" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
             </svg>
          </div>
        </div>
        <div class="zigzag-content">
          <h3>Proteins</h3>
          <p>We offer Sauced Turkey, Grilled Turkey, Chicken, Sauced Chicken, Chicken Wings, Sauced Chicken Wings, Gizzard, Beef, Fish, and Eggs.</p>
        </div>
      </article>

      <!-- Category 4: Snacks and Drinks -->
      <article class="zigzag-row reverse container" id="snacks-drinks" data-reveal>
        <div class="zigzag-content">
          <h3>Snacks and Drinks</h3>
          <p>We offer Ice Cream, Yoghurt Drinks, Fruits Juice, Tigernut, Beer, alongside snacks like Super Roll, Chicken Pie, and Small Chops.</p>
        </div>
        <div class="zigzag-image">
          <div class="placeholder-box" data-img-key="snacks_drinks">
             <svg class="placeholder-icon-large" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
             </svg>
          </div>
        </div>
      </article>

      <!-- Category 5: Side Dishes -->
      <article class="zigzag-row container" id="side-dishes" data-reveal>
        <div class="zigzag-image">
          <div class="placeholder-box portrait" data-img-key="side_dishes">
             <svg class="placeholder-icon-large" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
             </svg>
          </div>
        </div>
        <div class="zigzag-content">
          <h3>Side Dishes</h3>
          <p>We offer Salad, Moi moi, and Plantain.</p>
        </div>
      </article>

    </section>

    <!-- ══════════════════════════════════════════
         BUILD YOUR ORDER — interactive menu → WhatsApp
         ══════════════════════════════════════════ -->
    <section class="gfa-order" id="order-builder" data-reveal data-wa={waNumber}>
      <div class="container">
        <div class="gfa-order-head">
          <p class="section-eyebrow">Build Your Order</p>
          <h2 class="gfa-order-title">Tap. Add. <em>Send.</em></h2>
          <p class="gfa-order-sub">Pick your dishes and we'll pre-fill your order straight to our kitchen on WhatsApp — no app, no sign-up.</p>
        </div>

        <div class="order-chips" role="tablist" aria-label="Filter menu by category">
          <button class="order-chip is-active" type="button" data-cat="all" role="tab" aria-selected="true">All</button>
          {orderMenu.map((c) => (
            <button class="order-chip" type="button" data-cat={c.key} role="tab" aria-selected="false">{c.label}</button>
          ))}
        </div>

        <div class="order-grid">
          {orderItems.map((it) => (
            <article class="order-item" data-cat={it.cat} data-id={it.id} data-name={it.name} data-desc={it.desc} data-catlabel={it.catLabel} data-price={it.price ?? undefined} data-img={it.img ?? undefined} role="button" tabindex="0" aria-label={`View ${it.name} details`}>
              <span class={`order-item-avatar${it.img ? ' has-img' : ''}`} style={it.img ? `background-image:url("${it.img}")` : undefined} set:html={it.img ? '' : bowlIcon}></span>
              <span class="order-item-name">{it.name}</span>
              <div class="order-item-control">
                <button class="oi-add" type="button" aria-label={`Add ${it.name} to order`}>
                  Add
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
                </button>
                <div class="oi-step" hidden>
                  <button class="oi-dec" type="button" aria-label={`Remove one ${it.name}`}>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14"/></svg>
                  </button>
                  <span class="oi-qty" aria-live="polite">0</span>
                  <button class="oi-inc" type="button" aria-label={`Add one ${it.name}`}>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
                  </button>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Sticky order bar — appears once the cart has items -->
    <div class="order-bar" id="order-bar" role="region" aria-label="Your order">
      <div class="order-bar-info">
        <span class="order-bar-count">0 items</span>
        <button class="order-bar-clear" type="button">Clear</button>
      </div>
      <button class="order-bar-send" type="button">
        Send order on WhatsApp
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>

    <!-- Food detail modal -->
    <div class="food-modal" id="food-modal" hidden>
      <div class="food-modal-backdrop" data-close></div>
      <div class="food-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="fm-name">
        <button class="food-modal-close" type="button" data-close aria-label="Close">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
        <div class="food-modal-img" id="fm-img">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11h18a9 9 0 0 1-18 0Z"/><path d="M7.5 11a4.5 4.5 0 0 1 9 0"/><path d="M12 3.5v1.4"/></svg>
        </div>
        <div class="food-modal-content">
          <span class="food-modal-cat" id="fm-cat"></span>
          <h3 class="food-modal-name" id="fm-name"></h3>
          <p class="food-modal-desc" id="fm-desc"></p>
          <div class="food-modal-foot">
            <div class="order-item-control" id="fm-control">
              <button class="oi-add" type="button">
                Add to order
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
              </button>
              <div class="oi-step" hidden>
                <button class="oi-dec" type="button" aria-label="Remove one">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14"/></svg>
                </button>
                <span class="oi-qty" aria-live="polite">0</span>
                <button class="oi-inc" type="button" aria-label="Add one">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════════════
         CTA: ORDER NOW
         ══════════════════════════════════════════ -->
    <section class="cta-band" id="order" data-reveal>
      <div class="container">
        <div class="cta-band__inner">
          <p class="cta-band__eyebrow">Order Now</p>
          <h2 class="cta-band__title">Hungry? We've got <em>just the thing.</em></h2>
          <p class="cta-band__sub">Fresh, authentic Nigerian food prepared with love and delivered directly to you in Warri. Just say the word.</p>
          <a href="https://wa.me/2348077125775?text=Hi,%20I'd%20like%20to%20place%20a%20food%20order%20from%20Good%20Food%20Avenue..." class="cta-band__btn">
            Place Your Order
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <p class="cta-band__note">Via WhatsApp · Mon–Sun, 8am–10pm</p>
        </div>
      </div>
    </section>

  </main>


  <!-- Sticky WA CTA -->
  <a href="https://wa.me/2348077125775?text=Hi,%20I'd%20like%20to%20place%20a%20food%20order%20from%20Good%20Food%20Avenue..." class="sticky-wa-btn" aria-label="Chat on WhatsApp">
    <svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
  </a>

  <!-- Global Footer -->

  <Fragment slot="scripts">
    <script is:inline define:vars={{ brandImages }}>window.__BRAND_IMAGES__ = brandImages;</script>
    <script src="../../scripts/good-food-avenue-images.js"></script>
    <script src="../../scripts/good-food-avenue-order.js"></script>
  </Fragment>
</BaseLayout>
