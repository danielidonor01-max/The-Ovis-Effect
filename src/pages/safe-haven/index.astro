---
import { sanityClient } from "sanity:client";
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import NavModal from '../../components/NavModal.astro';
import { siteConfig } from '../../lib/siteConfig';
import { buildBrandImages } from '../../lib/brandImages';
import './style.css';

let brandData = null;
try {
  brandData = await sanityClient.fetch(`*[_type == "brand" && slug.current == "safe-haven"][0]`);
} catch (error) {
  console.warn("Sanity fetch failed:", error.message);
}

const pageTitle = brandData?.seo?.metaTitle || "Safe Haven Apartments | The Ovis Effect";
const metaDesc = brandData?.seo?.metaDescription || "The ultimate retreat, hidden in plain sight. Anonymous luxury apartment rentals in Warri, Delta State.";
const heroTitleHTML = brandData?.heroHeadline || "The Ultimate<br><em>Retreat,</em><br>Hidden in<br>Plain Sight.";
const heroSubText = brandData?.heroSub || "Anonymous luxury apartment rentals in Warri. Locations disclosed only upon confirmed booking.";

const brand = siteConfig.brands.find((b) => b.slug === 'safe-haven')!;
const localLinks = [{"href":"#lifestyle","label":"The Lifestyle"},{"href":"#apartment","label":"The Apartment"},{"href":"#gallery","label":"Gallery"},{"href":"#ecosystem","label":"Ecosystem"},{"href":"#booking","label":"Reservations"}];

// Gallery order: 1st image = main apartment showcase, rest = gallery grid
const brandImages = buildBrandImages(brandData, {
  gallerySlots: ['apartment_main', 'gallery_1', 'gallery_2', 'gallery_3', 'gallery_4'],
});
---
<BaseLayout title={pageTitle} description={metaDesc}>

  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  </Fragment>

  <Header variant="brand" brand={brand} />
  <NavModal variant="brand" activeSlug="safe-haven" localLinks={localLinks} />

<main>

    <!-- ══════════════════════════════════════════
         SECTION 1: HERO — FULL VIEWPORT
         ══════════════════════════════════════════ -->
    <section class="sh-hero-viewport" id="home">
      <!-- Animated background blobs for light theme -->
      <div class="sh-hero-blobs">
        <div class="sh-blob sh-blob-1"></div>
        <div class="sh-blob sh-blob-2"></div>
        <div class="sh-blob sh-blob-3"></div>
      </div>

      <div class="container sh-hero-inner">
        <!-- Mobile Logo -->
        <div class="mobile-hero-logo">
          <span class="subbrand-logo sh-cormorant-logo">Safe Haven</span>
        </div>
        
        <!-- Left: Typography block -->
        <div class="sh-hero-text-col">
          <p class="sh-eyebrow hero-animate-sub">Exclusive · Private · Anonymous</p>
          <h1 class="sh-hero-title hero-animate-title" set:html={heroTitleHTML}></h1>
          <p class="sh-hero-sub hero-animate-sub">{heroSubText}</p>
          <a href="https://wa.me/2348077125775?text=Hi,%20I'd%20like%20to%20inquire%20about%20availability%20at%20Safe%20Haven%20Luxury%20Apartments..." class="sh-cta-btn hero-animate-cta">
            Request Availability
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Right: Hero image placeholder -->
        <div class="sh-hero-image-col">
          <div class="sh-hero-img-wrap" data-img-key="hero">
            <div class="sh-img-placeholder">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="4" width="40" height="40" rx="3"/>
                <circle cx="16" cy="17" r="4"/>
                <polyline points="44 32 32 20 8 44"/>
              </svg>
            </div>
            <!-- Floating badge -->
            <div class="sh-floating-badge">
              <span class="badge-number">100%</span>
              <span class="badge-label">Private</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SECTION 2: STATEMENT / SCROLL TEXT
         ══════════════════════════════════════════ -->
    <section class="sh-statement-section" id="lifestyle" data-reveal>
      <div class="container">
        <div class="sh-statement-inner">
          <blockquote class="sh-statement-quote text-scrub">
            "Safe Haven operates on a strict reservation basis. Locations are disclosed only upon confirmed booking."
          </blockquote>
          <div class="sh-statement-meta">
            <div class="sh-meta-line"></div>
            <p>Safe Haven Apartments</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SECTION 3: THE APARTMENT — EDITORIAL SPLIT
         ══════════════════════════════════════════ -->
    <section class="sh-apartment-section" id="apartment" data-reveal>
      <div class="container">
        <div class="sh-apartment-header">
          <h2 class="sh-section-title">Your Private Retreat</h2>
          <p class="sh-section-sub">One apartment. Perfectly appointed. Available strictly by reservation.</p>
        </div>

        <div class="sh-apartment-split">

          <!-- Left: Apartment Image -->
          <div class="sh-apartment-image" data-img-key="apartment_main">
            <div class="sh-img-placeholder">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="4" width="40" height="40" rx="3"/><circle cx="16" cy="17" r="4"/><polyline points="44 32 32 20 8 44"/>
              </svg>
            </div>
            <div class="sh-apartment-tag">Safe Haven</div>
          </div>

          <!-- Right: Info + Amenities -->
          <div class="sh-apartment-info">
            <p class="sh-eyebrow">The Apartment</p>
            <h3 class="sh-apartment-name">Safe Haven</h3>
            <p class="sh-apartment-desc">A fully furnished, self-contained luxury apartment in the heart of Warri — curated for absolute comfort, total privacy, and complete discretion. Every detail has been considered so you don't have to.</p>

            <div class="sh-amenities-grid">
              <div class="sh-amenity-item"><span>Master Bedroom</span></div>
              <div class="sh-amenity-item"><span>Full Ensuite</span></div>
              <div class="sh-amenity-item"><span>Living Room</span></div>
              <div class="sh-amenity-item"><span>Dining Area</span></div>
              <div class="sh-amenity-item"><span>Fully Equipped Kitchen</span></div>
              <div class="sh-amenity-item"><span>High-Speed Wi-Fi</span></div>
              <div class="sh-amenity-item"><span>Smart TV &amp; A/V</span></div>
              <div class="sh-amenity-item"><span>Daily Housekeeping</span></div>
              <div class="sh-amenity-item"><span>Air Conditioning</span></div>
              <div class="sh-amenity-item"><span>Blackout Privacy Blinds</span></div>
              <div class="sh-amenity-item"><span>24/7 Concierge Access</span></div>
              <div class="sh-amenity-item"><span>100% Anonymous</span></div>
            </div>

            <a href="https://wa.me/2348077125775?text=Hi,%20I'd%20like%20to%20inquire%20about%20availability%20at%20Safe%20Haven%20Luxury%20Apartments..." class="sh-cta-btn">
              Check Availability
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SECTION 4: GALLERY — MOSAIC GRID
         ══════════════════════════════════════════ -->
    <section class="sh-gallery-section" id="gallery" data-reveal>
      <div class="container">
        <div class="sh-gallery-header">
          <h2 class="sh-section-title">Interior Details</h2>
          <a href="https://wa.me/2348077125775?text=Hi,%20I'd%20like%20to%20see%20the%20full%20gallery%20for%20Safe%20Haven..." class="sh-text-link">
            Request Full Gallery <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="sh-gallery-mosaic">
          <div class="sh-gallery-item sh-gallery-item--tall" data-img-key="gallery_1">
            <div class="sh-img-placeholder">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1"><rect x="4" y="4" width="40" height="40" rx="3"/><circle cx="16" cy="17" r="4"/><polyline points="44 32 32 20 8 44"/></svg>
            </div>
            <div class="sh-gallery-label">Living Room</div>
          </div>
          <div class="sh-gallery-item" data-img-key="gallery_2">
            <div class="sh-img-placeholder">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1"><rect x="4" y="4" width="40" height="40" rx="3"/><circle cx="16" cy="17" r="4"/><polyline points="44 32 32 20 8 44"/></svg>
            </div>
            <div class="sh-gallery-label">Master Bedroom</div>
          </div>
          <div class="sh-gallery-item" data-img-key="gallery_3">
            <div class="sh-img-placeholder">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1"><rect x="4" y="4" width="40" height="40" rx="3"/><circle cx="16" cy="17" r="4"/><polyline points="44 32 32 20 8 44"/></svg>
            </div>
            <div class="sh-gallery-label">Ensuite Bath</div>
          </div>
          <div class="sh-gallery-item sh-gallery-item--wide" data-img-key="gallery_4">
            <div class="sh-img-placeholder">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1"><rect x="4" y="4" width="40" height="40" rx="3"/><circle cx="16" cy="17" r="4"/><polyline points="44 32 32 20 8 44"/></svg>
            </div>
            <div class="sh-gallery-label">Private Terrace</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SECTION 5: ECOSYSTEM (In-House Services)
         ══════════════════════════════════════════ -->
    <section class="sh-ecosystem-section" id="ecosystem" data-reveal>
      <div class="container">
        <div class="sh-ecosystem-header">
          <h2 class="sh-section-title">An Exclusive Ecosystem</h2>
          <p class="sh-section-sub">Safe Haven is seamlessly woven into The Ovis Effect's world. Every comfort is a few steps — or a message — away.</p>
        </div>

        <div class="sh-eco-grid">

          <div class="sh-eco-card">
            <div class="sh-eco-icon-wrap">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            </div>
            <h3 class="sh-eco-title">Private Comfort</h3>
            <p class="sh-eco-body">Premium, fully-furnished rooms designed for total anonymity, absolute peace, and maximum discretion at all times.</p>
          </div>

          <a href="/good-food-avenue/" class="sh-eco-card sh-eco-card--link">
            <div class="sh-eco-icon-wrap">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 11l19-9-9 19-2-8-8-2z"/>
              </svg>
            </div>
            <h3 class="sh-eco-title">In-Suite Dining</h3>
            <p class="sh-eco-body">Order premium Nigerian dishes, grills, and fresh fruit drinks directly to your room via Good Food Avenue — our in-house culinary brand.</p>
            <span class="sh-eco-link-tag">Good Food Avenue →</span>
          </a>

          <a href="/urovi-spa/" class="sh-eco-card sh-eco-card--link">
            <div class="sh-eco-icon-wrap">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <h3 class="sh-eco-title">In-Room Therapy</h3>
            <p class="sh-eco-body">Experience restorative, organic treatments delivered to your door by Urovi Spa's expert therapists. Wellness, on your schedule.</p>
            <span class="sh-eco-link-tag">Urovi Spa →</span>
          </a>

          <div class="sh-eco-card">
            <div class="sh-eco-icon-wrap">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </div>
            <h3 class="sh-eco-title">Total Discretion</h3>
            <p class="sh-eco-body">Your identity and location remain confidential. Our concierge team operate under a strict non-disclosure protocol for every reservation.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SECTION 6: BOOKING CTA
         ══════════════════════════════════════════ -->
    <section class="sh-booking-section" id="booking" data-reveal>
      <div class="container">
        <div class="sh-booking-inner">
          <div class="sh-booking-text">
            <p class="sh-eyebrow">Reservations Only</p>
            <h2 class="sh-booking-title">Ready to experience<br><em>refined privacy?</em></h2>
            <p class="sh-booking-sub">Our concierge team will guide you through the booking process. No public listings. No walk-ins. Pure, curated access.</p>
          </div>
          <div class="sh-booking-action">
            <a href="https://wa.me/2348077125775?text=Hi,%20I'd%20like%20to%20inquire%20about%20availability%20at%20Safe%20Haven%20Luxury%20Apartments..." class="sh-cta-btn sh-cta-btn--dark">
              Chat with our Concierge
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <p class="sh-booking-note">Via WhatsApp · Mon–Sat, 8am–10pm</p>
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- Sticky WA CTA -->
  <a href="https://wa.me/2348077125775?text=Hi,%20I'd%20like%20to%20inquire%20about%20availability%20at%20Safe%20Haven%20Luxury%20Apartments..." class="sticky-wa-btn" aria-label="Chat on WhatsApp">
    <svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
  </a>

  <!-- ══════════════════════════════════════════
       GLOBAL FOOTER
       ══════════════════════════════════════════ -->

  <Fragment slot="scripts">
    <script is:inline define:vars={{ brandImages }}>window.__BRAND_IMAGES__ = brandImages;</script>
    <script src="../../scripts/safe-haven-images.js"></script>
  </Fragment>
</BaseLayout>
