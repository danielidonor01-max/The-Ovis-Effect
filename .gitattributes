# Normalise line endings so automated transforms and cross-OS clones stay consistent
* text=auto eol=lf

*.astro text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.ts    text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.html  text eol=lf

# Binary assets — never normalise
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.webp binary
*.svg text eol=lf
*.pdf binary
*.ico binary
